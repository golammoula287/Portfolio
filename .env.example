# Copy to .env.local for development. Real values also get set per-environment
# (Production/Preview/Development) in the Vercel dashboard.

# MongoDB Atlas
MONGODB_URI=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Auth
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Hidden admin route slug, e.g. adm-7f3k9x2q1z — rotate by changing this and
# redeploying, no code change needed.
ADMIN_ROUTE_SLUG=

# Only read by `npm run seed:admin` to create/update the single admin user.
# Not read by the app at runtime — safe to unset after seeding.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Chatbot (Groq — free key at https://console.groq.com). If unset, the
# assistant widget stays visible but replies that it isn't configured yet.
GROQ_API_KEY=

# Contact form email notifications (Resend — free key at https://resend.com).
# Optional: messages always save to the admin inbox; this also emails you.
# With the default sender you can only deliver to the address you signed up
# with. Set CONTACT_FROM_EMAIL only after verifying your own domain in Resend.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
